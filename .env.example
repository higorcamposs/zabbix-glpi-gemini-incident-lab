# =============================================================================
# zabbix-glpi-gemini-incident-lab - Environment variables
# Copy to .env and fill in your local values. Never commit .env with real secrets.
# =============================================================================

# --- Application ---
APP_ENV=local
LOG_LEVEL=INFO
API_PORT=8000
# Lab default (change if exposing beyond local machine).
WEBHOOK_SHARED_SECRET=lab-webhook-secret

# --- AI provider ---
# Gemini real is the primary path for this lab (recommended for students).
# Use AI_PROVIDER=mock apenas se voce nao tiver uma chave Gemini.
AI_PROVIDER=gemini

# --- Gemini (Google AI) ---
# Get your key at: https://aistudio.google.com/apikey
# See docs/gemini-api-setup.md for step-by-step instructions.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-lite

# --- GLPI REST API ---
# Use internal Docker hostname when running via docker compose
GLPI_BASE_URL=http://glpi/apirest.php
# Optional when using app token mode
GLPI_APP_TOKEN=
# Optional when using token mode
GLPI_USER_TOKEN=
# Recommended for this lab: credential mode (no manual token generation required)
GLPI_API_USERNAME=zabbix-integration
GLPI_API_PASSWORD=zabbix-integration-pass
GLPI_API_CLIENT_NAME=zabbix-glpi-gemini-lab
GLPI_DEFAULT_ENTITY_ID=0
GLPI_DEFAULT_CATEGORY_ID=
GLPI_DEFAULT_REQUESTER_ID=
GLPI_DEFAULT_TECHNICIAN_ID=
GLPI_LAB_CATEGORY_NAME=Zabbix Alerts
# true = create TicketTask checklist on Gemini-enriched tickets
GLPI_CREATE_TASK=true
GLPI_BOOTSTRAP_TIMEOUT=600

# --- Demo auto-trigger ---
# true = send cpu.util=95 to both lab hosts after bootstrap (two GLPI tickets)
# false = wait for manual scripts in examples/
AUTO_TRIGGER_DEMO_ALERTS=true

# --- Zabbix (URLs for students / host machine) ---
ZABBIX_URL=http://localhost:8080
ZABBIX_API_URL=http://localhost:8080/api_jsonrpc.php
# Lab defaults for bootstrap login (change if needed).
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix
ZABBIX_WEB_PORT=8080
PUBLIC_ZABBIX_URL=http://localhost:8080
LAB_RUNBOOK_URL=https://github.com/SEU_USUARIO/zabbix-glpi-gemini-incident-lab

# --- GLPI (URL for students / host machine) ---
GLPI_URL=http://localhost:8081
GLPI_WEB_PORT=8081

# --- Zabbix database (docker-compose) ---
# Lab defaults (change if needed)
ZABBIX_DB_PASSWORD=zbx_lab_pass
ZABBIX_DB_ROOT_PASSWORD=zbx_lab_root_pass

# --- GLPI database (docker-compose) ---
# Lab defaults (change if needed)
GLPI_DB_PASSWORD=glpi_lab_pass
GLPI_DB_ROOT_PASSWORD=glpi_lab_root_pass
